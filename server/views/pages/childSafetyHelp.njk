{% extends "partials/layout.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}
{% from "macros/title.njk" import getTitle with context %}

{% block pageTitle %}
  {{ getTitle('childSafetyHelp', errors) }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {{ __("exitThisPage")  | safe }}

      <h1 class="govuk-heading-l">
        {{ __("pages.childSafetyHelp.title") }}
      </h1>

      {{ govukWarningText({
        text: __("pages.childSafetyHelp.content.warningText"),
        iconFallbackText: "Warning"
      }) }}

      <p class="govuk-body">
        {{ __("pages.childSafetyHelp.content.continueDescription") }}
      </p>

      {{ govukButton({
        text: __("continue"),
        href: paths.DOMESTIC_ABUSE,
        classes: "govuk-button--primary"
      }) }}

      <h2 class="govuk-heading-m">
        {{ __("pages.childSafetyHelp.content.getHelpProtecting.title") }}
      </h2>
      <p class="govuk-body">
        {{ __("pages.childSafetyHelp.content.getHelpProtecting.importantToRemember") }}
      </p>
      <p class="govuk-body">
        {{ __("pages.childSafetyHelp.content.getHelpProtecting.experiencedAbuse") | safe }}
      </p>
      <p class="govuk-body">
        {{ __("pages.childSafetyHelp.content.getHelpProtecting.findOut") | safe }}
      </p>

      <h2 class="govuk-heading-m">
        {{ __("pages.childSafetyHelp.content.helpAndSupport.title") }}
      </h2>
      <p class="govuk-body">
        {{ __("pages.childSafetyHelp.content.helpAndSupport.description") }}
      </p>

      <dl class="govuk-summary-list">
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key govuk-summary-list__key-mediation-width">
          </dt>
          <dd class="govuk-summary-list__value">
          </dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key govuk-summary-list__key-mediation-width">
            {{ __("pages.childSafetyHelp.content.helpAndSupport.table.rowOne.heading") | safe }}
          </dt>
          <dd class="govuk-summary-list__value">
            {{ __("pages.childSafetyHelp.content.helpAndSupport.table.rowOne.data") | safe }}
          </dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key govuk-summary-list__key-mediation-width">
            {{ __("pages.childSafetyHelp.content.helpAndSupport.table.rowTwo.heading") | safe }}
          </dt>
          <dd class="govuk-summary-list__value">
            {{ __("pages.childSafetyHelp.content.helpAndSupport.table.rowTwo.data") | safe }}
          </dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key govuk-summary-list__key-mediation-width">
            {{ __("pages.childSafetyHelp.content.helpAndSupport.table.rowThree.heading") | safe }}
          </dt>
          <dd class="govuk-summary-list__value">
            {{ __("pages.childSafetyHelp.content.helpAndSupport.table.rowThree.data") | safe }}
          </dd>
        </div>
      </dl>
    </div>
    <div class="govuk-grid-column-one-third">
      {% include "partials/exitThisPage.njk" %}
    </div>
  </div>
{% endblock %}
