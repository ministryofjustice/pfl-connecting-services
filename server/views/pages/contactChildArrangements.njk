{% extends "partials/layout.njk" %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "macros/title.njk" import getTitle %}

{% block pageTitle %}
  {{ getTitle(formFields.CONTACT_CHILD_ARRANGEMENTS, errors) }}
{% endblock %}

{% set legendText %}
  {{ __("pages.contactChildArrangements.title") | safe }}
{% endset %}

{% set radioItems = [
  { value: "yes", text: __("pages.contactChildArrangements.content.options.first")  },
  { value: "no", text: __("pages.contactChildArrangements.content.options.second") },
  { value: "no-details", text: __("pages.contactChildArrangements.content.options.third") },
  { value: "not-response", text: __("pages.contactChildArrangements.content.options.fourth") }
] %}

{% block content %}
   <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {{ __("exitThisPage")  | safe }}

      {% include "partials/errorSummary.njk" %}
      <form class="form" action="{{ paths.CONTACT_CHILD_ARRANGEMENTS }}" method="post">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

        {% set radioItems = [
          { value: "yes", text: __("pages.contactChildArrangements.content.options.first")  },
          { value: "no", text: __("pages.contactChildArrangements.content.options.second") },
          { value: "no-details", text: __("pages.contactChildArrangements.content.options.third") },
          { value: "not-response", text: __("pages.contactChildArrangements.content.options.fourth") }
        ] %}

        {{ govukRadios({
          name: formFields.CONTACT_CHILD_ARRANGEMENTS,
          fieldset: {
            legend: {
              text: legendText,
              isPageHeading: true,
              classes: "govuk-fieldset__legend--l"
            }
          },
          items: radioItems,
          errorMessage: errors | findError(formFields.CONTACT_CHILD_ARRANGEMENTS)
        }) }}

        {{ govukButton({
          text: __("continue")
        }) }}

      </form>
    </div>
    <div class="govuk-grid-column-one-third">
      {% include "partials/exitThisPage.njk" %}
    </div>
  </div>
{% endblock %}
