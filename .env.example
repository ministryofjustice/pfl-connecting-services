# ==========================================
# Basic Application Configuration
# ==========================================

# The local port the server will listen on
PORT=3000

# Application version identifier for tracking deployments
BUILD_NUMBER=1_0_0

# Specific Git commit hash and branch name for build auditing
GIT_REF=xxxxxxxxxxxxxxxxxxxxxxxx
GIT_BRANCH=xxxxxxxxxxxx

# Protocol setting; set to 'true' in production to enforce SSL
USE_HTTPS=false

# Cache header duration for static files (e.g., images, CSS, JS)
STATIC_RESOURCE_CACHE_DURATION=1h

# Secret key used to sign session cookies (MUST be changed in production)
SESSION_SECRET=app-insecure-default-session

# Duration of user inactivity before the web session expires
WEB_SESSION_TIMEOUT_IN_MINUTES=30

# ==========================================
# Redis Configuration
# ==========================================

# Toggle for external caching logic; set to 'true' to use Redis
CACHE_ENABLED=false

# Hostname/IP address for the Redis server
CACHE_HOST=localhost

# Password for Redis authentication
CACHE_PASSWORD=cache_password

# Toggle for encrypted connection to the Redis server
CACHE_TLS_ENABLED=false

# ==========================================
# Application-Specific Configuration
# ==========================================

# Environment mode (development, staging, or production)
NODE_ENV=development

# Comma-separated list of passwords for early-access features
BETA_ACCESS_PASSWORDS=parent-planner,password2

# Enable or disable the authentication middleware layer
USE_AUTH=true

# Feature flag for multi-language (Welsh) support
INCLUDE_WELSH_LANGUAGE=true

# Redirect URL for the user feedback form
FEEDBACK_URL=https://feedback.example.com

# Support/Admin email address for automated notifications
CONTACT_EMAIL=test@example.com

# ISO timestamp indicating when the preview period for the app ends
PREVIEW_END=2025-04-30T23:59:59

# Detail level for system logs (debug, info, warn, error)
LOG_LEVEL=debug

# Salt/Secret used for generating secure hashes (e.g., ID obfuscation)
HASH_SECRET=local-dev-secret
